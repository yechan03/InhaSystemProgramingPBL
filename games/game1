#!/bin/bash
# VI-RPG (점수 통합 버전)
if [ -z "$BASH_VERSION" ]; then
    exec bash "$0" "$@"
fi

ESC=$(printf '\033')
R="${ESC}[31m"    BR="${ESC}[91m"   G="${ESC}[32m"   BG="${ESC}[92m"
Y="${ESC}[33m"    BY="${ESC}[93m"   C="${ESC}[36m"   BC="${ESC}[96m"
M="${ESC}[35m"    BM="${ESC}[95m"   W="${ESC}[37m"   BW="${ESC}[97m"
GR="${ESC}[90m"   BOLD="${ESC}[1m"  RST="${ESC}[0m"
BG_Y="${ESC}[43m" BG_R="${ESC}[41m"

c()  { echo -n "${1}${2}${RST}"; }
cl() { echo "${1}${2}${RST}"; }
clear_screen() { echo "${ESC}[2J${ESC}[H"; }

PLAYER_MAX_HP=5
PLAYER_ATK=2
GOBLIN_MAX_HP=3
BOSS_MAX_HP=10
GOLD_REWARD=5
MAP_ROWS=13
MAP_COLS=21

# 점수: 0~255 범위 내로 조정 (lobby.c의 WEXITSTATUS 제한)
SCORE_GOBLIN=10
SCORE_BOSS=80
SCORE_LEVELUP=15
SCORE_CLEAR_BONUS=50
SCORE_HP_BONUS=5
SCORE_TURN_PENALTY=1

PLAYER_ROW=0; PLAYER_COL=0
PLAYER_HP=$PLAYER_MAX_HP
PLAYER_ATTACK=$PLAYER_ATK
PLAYER_GOLD=0
PLAYER_LEVEL=1
TURN=0
KILL_COUNT=0
LAST_MSG=""
SKILL_HITS=0
BOSS_DEAD=0
SCORE=0
PLAYER_NAME="${1:-player}"

LEVEL_TABLE="1:1 3:1 6:2"

declare -a BOARD
declare -a GOBLIN_HP
declare -a BOSS_HP

idx()     { echo $(( $1 * MAP_COLS + $2 )); }
get_tile(){ local i; i=$(idx $1 $2); echo "${BOARD[$i]:-#}"; }
set_tile(){ local i; i=$(idx $1 $2); BOARD[$i]="$3"; }
get_ghp() { local i; i=$(idx $1 $2); echo "${GOBLIN_HP[$i]:-0}"; }
set_ghp() { local i; i=$(idx $1 $2); GOBLIN_HP[$i]=$3; }
get_bhp() { local i; i=$(idx $1 $2); echo "${BOSS_HP[$i]:-0}"; }
set_bhp() { local i; i=$(idx $1 $2); BOSS_HP[$i]=$3; }

generate_map() {
    local r c i
    for (( r=0; r<MAP_ROWS; r++ )); do
        for (( c=0; c<MAP_COLS; c++ )); do
            i=$(idx $r $c)
            if (( r==0 || r==MAP_ROWS-1 || c==0 || c==MAP_COLS-1 )); then
                BOARD[$i]='#'
            else
                BOARD[$i]='.'
            fi
            GOBLIN_HP[$i]=0
            BOSS_HP[$i]=0
        done
    done

    local obstacles=$(( RANDOM % 11 + 15 ))
    local placed=0 attempts=0 rnd
    while (( placed < obstacles && attempts < 500 )); do
        r=$(( RANDOM % (MAP_ROWS-2) + 1 ))
        c=$(( RANDOM % (MAP_COLS-2) + 1 ))
        i=$(idx $r $c)
        if [[ "${BOARD[$i]}" == '.' ]]; then
            rnd=$(( RANDOM % 4 ))
            if   (( rnd == 0 || rnd == 1 )); then BOARD[$i]='#'
            elif (( rnd == 2 ));              then BOARD[$i]='T'
            else                                   BOARD[$i]='t'
            fi
            (( placed++ ))
        fi
        (( attempts++ ))
    done

    PLAYER_ROW=-1; PLAYER_COL=-1
    for (( r=1; r<MAP_ROWS-1; r++ )); do
        for (( c=1; c<MAP_COLS-1; c++ )); do
            i=$(idx $r $c)
            if [[ "${BOARD[$i]}" == '.' && $PLAYER_ROW == -1 ]]; then
                PLAYER_ROW=$r; PLAYER_COL=$c
            fi
        done
    done

    place_char() {
        local ch=$1 count=$2 p=0 att=0
        while (( p < count && att < 1000 )); do
            r=$(( RANDOM % (MAP_ROWS-2) + 1 ))
            c=$(( RANDOM % (MAP_COLS-2) + 1 ))
            i=$(idx $r $c)
            if [[ "${BOARD[$i]}" == '.' ]] && ! (( r==PLAYER_ROW && c==PLAYER_COL )); then
                BOARD[$i]="$ch"
                if [[ "$ch" == '1' || "$ch" == '2' || "$ch" == '3' ]]; then
                    GOBLIN_HP[$i]=$GOBLIN_MAX_HP
                fi
                if [[ "$ch" == 'B' ]]; then
                    BOSS_HP[$i]=$BOSS_MAX_HP
                fi
                (( p++ ))
            fi
            (( att++ ))
        done
    }

    place_char 'H' 2
    place_char '1' 1
    place_char '2' 1
    place_char '3' 1
    place_char 'B' 1
}

hp_bar() {
    local cur=$1 max=$2 col=$3
    local filled=$(( cur * 10 / max ))
    (( filled < 0 )) && filled=0
    (( filled > 10 )) && filled=10
    local bar="" i
    for (( i=0; i<10; i++ )); do
        if (( i < filled )); then
            bar="${bar}${col}█${RST}"
        else
            bar="${bar}${GR}░${RST}"
        fi
    done
    echo -n "[${bar}]"
}

colored_tile() {
    local tile=$1 hi=$2
    if [[ "$hi" == "1" ]]; then
        echo -n "${BG_Y}${BOLD}${BR}*${RST}"
        return
    fi
    case "$tile" in
        '#') echo -n "${GR}█${RST}" ;;
        'T') echo -n "${G}♣${RST}" ;;
        't') echo -n "${BG}♠${RST}" ;;
        'H') echo -n "${BC}H${RST}" ;;
        '1') echo -n "${BR}1${RST}" ;;
        '2') echo -n "${BR}2${RST}" ;;
        '3') echo -n "${BR}3${RST}" ;;
        'B') echo -n "${BOLD}${M}B${RST}" ;;
        '.') echo -n "${GR}.${RST}" ;;
        *)   echo -n "$tile" ;;
    esac
}

find_char_hp() {
    local ch=$1 r c i
    for (( r=0; r<MAP_ROWS; r++ )); do
        for (( c=0; c<MAP_COLS; c++ )); do
            i=$(idx $r $c)
            if [[ "${BOARD[$i]}" == "$ch" ]]; then
                if [[ "$ch" == 'B' ]]; then
                    echo "${BOSS_HP[$i]:-0}"; return
                fi
                echo "${GOBLIN_HP[$i]:-0}"; return
            fi
        done
    done
    echo "0"
}

BOX_W=46
box_sep() {
    echo -n "  ${BOLD}${C}"
    local i; for (( i=0; i<BOX_W+2; i++ )); do printf '─'; done
    echo "$RST"
}
box_line() {
    echo "  $1"
}

render() {
    local skill_cells="$1"
    clear_screen
    box_sep
    box_line "${BOLD}${BY}       >>>  VI-RPG : ${PLAYER_NAME}님의 모험  <<<${RST}"
    box_sep
    echo ""
    echo "${BOLD}${W}  [ 게임 맵 ]${RST}"
    local r c tile hi cell
    for (( r=0; r<MAP_ROWS; r++ )); do
        echo -n "  "
        for (( c=0; c<MAP_COLS; c++ )); do
            tile=$(get_tile $r $c)
            hi=0
            if [[ -n "$skill_cells" ]]; then
                for cell in $skill_cells; do
                    if [[ "$cell" == "${r},${c}" ]]; then hi=1; break; fi
                done
            fi
            if (( r == PLAYER_ROW && c == PLAYER_COL )); then
                echo -n "${BOLD}${BY}♥${RST}"
            else
                colored_tile "$tile" "$hi"
            fi
            echo -n " "
        done
        echo ""
    done
    echo ""
    box_sep
    local hp_col
    if (( PLAYER_HP > 2 )); then hp_col="$BG"; else hp_col="$BR"; fi
    local hbar; hbar=$(hp_bar "$PLAYER_HP" "$PLAYER_MAX_HP" "$hp_col")
    box_line " ${BOLD}TURN ${TURN}${RST}  HP:${hp_col}${PLAYER_HP}${RST}/${PLAYER_MAX_HP} ${hbar}"
    box_line " ${Y}Lv:${PLAYER_LEVEL}${RST}  ${BY}ATK:${PLAYER_ATTACK}${RST}  ${Y}Gold:${PLAYER_GOLD}${RST}  ${GR}Kill:${KILL_COUNT}${RST}"
    box_line " ${BOLD}${BC}★ SCORE: ${SCORE}${RST}"
    box_sep
    local boss_hp g1_hp g2_hp g3_hp
    boss_hp=$(find_char_hp 'B')
    g1_hp=$(find_char_hp '1')
    g2_hp=$(find_char_hp '2')
    g3_hp=$(find_char_hp '3')
    local b_col; (( boss_hp > BOSS_MAX_HP/2 )) && b_col="$M" || b_col="$BR"
    local bbar; bbar=$(hp_bar "$boss_hp" "$BOSS_MAX_HP" "$b_col")
    box_line " ${BOLD}${M}BOSS${RST} ${b_col}${boss_hp}${RST}/${BOSS_MAX_HP} ${bbar}"
    box_line " ${BR}G1:${g1_hp}/${GOBLIN_MAX_HP}${RST}  ${BR}G2:${g2_hp}/${GOBLIN_MAX_HP}${RST}  ${BR}G3:${g3_hp}/${GOBLIN_MAX_HP}${RST}"
    box_sep
    box_line " 이동:${BY}w/a/s/d${RST}  공격:${BY}SPACE${RST}  스킬:${BY}e${RST}  종료:${BY}q${RST}"
    box_sep
    if [[ -n "$LAST_MSG" ]]; then
        echo ""
        box_line "$LAST_MSG"
    fi
}

do_move() {
    local key=$1
    local nr=$PLAYER_ROW nc=$PLAYER_COL
    case "$key" in
        w|W) (( nr-- )) ;;
        s|S) (( nr++ )) ;;
        a|A) (( nc-- )) ;;
        d|D) (( nc++ )) ;;
        *) return ;;
    esac
    (( nr < 0 || nr >= MAP_ROWS || nc < 0 || nc >= MAP_COLS )) && return
    local tile; tile=$(get_tile $nr $nc)
    case "$tile" in
        '#'|'T'|'t') return ;;
    esac
    case "$tile" in
        '1'|'2'|'3')
            (( PLAYER_HP-- ))
            LAST_MSG=" ${BR}! 고블린에게 피해를 입었습니다! HP-1${RST}"
            ;;
        'B')
            (( PLAYER_HP -= 2 ))
            LAST_MSG=" ${BR}!! 보스에게 피해를 입었습니다! HP-2${RST}"
            ;;
        'H')
            local heal=$(( PLAYER_MAX_HP - PLAYER_HP ))
            (( heal > GOLD_REWARD )) && heal=$GOLD_REWARD
            if (( heal > 0 )); then
                (( PLAYER_HP += heal ))
                LAST_MSG=" ${BC}+ 상점에서 HP ${heal} 회복!${RST}"
            else
                LAST_MSG=" ${GR}이미 HP가 최대입니다.${RST}"
            fi
            ;;
    esac
    PLAYER_ROW=$nr
    PLAYER_COL=$nc
}

do_attack() {
    local r c tile hp
    local dirs="-1,0 1,0 0,-1 0,1"
    local dir dr dc
    for dir in $dirs; do
        dr="${dir%%,*}"; dc="${dir##*,}"
        r=$(( PLAYER_ROW + dr )); c=$(( PLAYER_COL + dc ))
        (( r<0 || r>=MAP_ROWS || c<0 || c>=MAP_COLS )) && continue
        tile=$(get_tile $r $c)
        case "$tile" in
            '1'|'2'|'3')
                hp=$(get_ghp $r $c)
                if (( hp > 0 )); then
                    (( hp -= PLAYER_ATTACK )); (( hp < 0 )) && hp=0
                    set_ghp $r $c $hp
                fi
                ;;
            'B')
                hp=$(get_bhp $r $c)
                if (( hp > 0 )); then
                    (( hp -= PLAYER_ATTACK )); (( hp < 0 )) && hp=0
                    set_bhp $r $c $hp
                fi
                ;;
        esac
    done
}

do_skill() {
    SKILL_HITS=0
    local skill_dmg=$(( PLAYER_ATTACK / 2 ))
    (( skill_dmg < 1 )) && skill_dmg=1
    local cells="" dr dc r c
    for dr in -1 0 1; do
        for dc in -1 0 1; do
            (( dr==0 && dc==0 )) && continue
            r=$(( PLAYER_ROW + dr )); c=$(( PLAYER_COL + dc ))
            (( r<0 || r>=MAP_ROWS || c<0 || c>=MAP_COLS )) && continue
            cells="${cells}${r},${c} "
        done
    done
    LAST_MSG=" ${BOLD}${BY}** 스킬 범위 표시중... **${RST}"
    render "$cells"
    sleep 0.4
    local tile hp cell
    for cell in $cells; do
        r="${cell%%,*}"; c="${cell##*,}"
        tile=$(get_tile $r $c)
        case "$tile" in
            '1'|'2'|'3')
                hp=$(get_ghp $r $c)
                if (( hp > 0 )); then
                    (( hp -= skill_dmg )); (( hp < 0 )) && hp=0
                    set_ghp $r $c $hp; (( SKILL_HITS++ ))
                fi
                ;;
            'B')
                hp=$(get_bhp $r $c)
                if (( hp > 0 )); then
                    (( hp -= skill_dmg )); (( hp < 0 )) && hp=0
                    set_bhp $r $c $hp; (( SKILL_HITS++ ))
                fi
                ;;
        esac
    done
}

check_dead() {
    BOSS_DEAD=0
    local r c i tile hp
    for (( r=0; r<MAP_ROWS; r++ )); do
        for (( c=0; c<MAP_COLS; c++ )); do
            i=$(idx $r $c)
            tile="${BOARD[$i]}"
            case "$tile" in
                '1'|'2'|'3')
                    hp="${GOBLIN_HP[$i]:-0}"
                    if (( hp <= 0 )); then
                        BOARD[$i]='.'
                        (( PLAYER_GOLD += GOLD_REWARD ))
                        (( KILL_COUNT++ ))
                        (( SCORE += SCORE_GOBLIN ))
                    fi
                    ;;
                'B')
                    hp="${BOSS_HP[$i]:-0}"
                    if (( hp <= 0 )); then
                        BOARD[$i]='.'
                        (( PLAYER_GOLD += GOLD_REWARD ))
                        (( KILL_COUNT++ ))
                        (( SCORE += SCORE_BOSS ))
                        BOSS_DEAD=1
                    fi
                    ;;
            esac
        done
    done
}

check_levelup() {
    local lv_idx=$(( PLAYER_LEVEL - 1 ))
    local idx_cnt=0 entry needed bonus
    for entry in $LEVEL_TABLE; do
        if (( idx_cnt == lv_idx )); then
            needed="${entry%%:*}"; bonus="${entry##*:}"
            if (( KILL_COUNT >= needed )); then
                (( PLAYER_LEVEL++ ))
                (( PLAYER_ATTACK += bonus ))
                (( SCORE += SCORE_LEVELUP ))
                return 0
            fi
            break
        fi
        (( idx_cnt++ ))
    done
    return 1
}

finalize_score() {
    local turn_penalty=$(( TURN * SCORE_TURN_PENALTY ))
    (( SCORE -= turn_penalty ))
    if (( BOSS_DEAD == 1 )); then
        (( SCORE += SCORE_CLEAR_BONUS ))
        (( SCORE += PLAYER_HP * SCORE_HP_BONUS ))
    fi
    (( SCORE < 0 )) && SCORE=0
    (( SCORE > 255 )) && SCORE=255
}

show_result() {
    local result=$1
    echo ""
    if [[ "$result" == "CLEAR" ]]; then
        cl "${BOLD}${BY}" "  +========================================+"
        cl "${BOLD}${BY}" "  |          *** GAME CLEAR ***            |"
        cl "${BOLD}${BY}" "  +========================================+"
    elif [[ "$result" == "DEAD" ]]; then
        cl "${BOLD}${BR}" "  +========================================+"
        cl "${BOLD}${BR}" "  |          --- GAME OVER ---             |"
        cl "${BOLD}${BR}" "  +========================================+"
    else
        cl "${BOLD}${GR}" "  +========================================+"
        cl "${BOLD}${GR}" "  |          -- 게임 종료 --                |"
        cl "${BOLD}${GR}" "  +========================================+"
    fi
    echo ""
    printf "  플레이어 : %s\n" "$PLAYER_NAME"
    printf "  킬 수    : %d\n" "$KILL_COUNT"
    printf "  레벨     : %d\n" "$PLAYER_LEVEL"
    printf "  남은 HP  : %d\n" "$PLAYER_HP"
    printf "  플레이턴: %d\n" "$TURN"
    printf "  ${BOLD}${BY}최종 점수: %d${RST}\n" "$SCORE"
    echo ""
    echo "  ${BY}엔터를 누르면 로비로 돌아갑니다...${RST}"
    IFS= read -r _dummy
}

show_title() {
    clear_screen
    echo ""
    cl "${BOLD}${BY}" "  ╔══════════════════════════════════════════╗"
    cl "${BOLD}${BY}" "  ║         VI-RPG : VI RPG 던전             ║"
    cl "${BOLD}${BY}" "  ╚══════════════════════════════════════════╝"
    echo ""
    echo "  ${BY}플레이어: ${PLAYER_NAME}${RST}"
    echo ""
    cl "${C}"  "  ┌─────────────────────────────────────────┐"
    cl "${C}"  "  │  이동: w(위) a(왼) s(아래) d(오)        │"
    cl "${C}"  "  │  공격: SPACE  스킬: e  종료: q          │"
    cl "${C}"  "  ├─────────────────────────────────────────┤"
    cl "${C}"  "  │  ♥=나  1/2/3=고블린  B=보스  H=상점     │"
    cl "${C}"  "  │  ♣/♠=나무  █=벽  .=이동가능             │"
    cl "${C}"  "  ├─────────────────────────────────────────┤"
    cl "${C}"  "  │  [점수] 고블린+10  보스+80  레벨업+15   │"
    cl "${C}"  "  │  클리어 +50, 남은HP×5, 턴당 -1          │"
    cl "${C}"  "  │  (최대 255점)                           │"
    cl "${C}"  "  └─────────────────────────────────────────┘"
    echo ""
    echo "  ${BY}엔터를 누르면 시작합니다...${RST}"
    IFS= read -r _dummy
}

read_key() {
    local key="" OLD_STTY
    OLD_STTY=$(stty -g 2>/dev/null)
    stty cbreak -echo 2>/dev/null
    IFS= read -r -s -n1 key
    stty "$OLD_STTY" 2>/dev/null
    case "$key" in
        " ")    echo "space" ;;
        ""|\
$'\n'|\
$'\r')  echo "enter" ;;
        *)      echo "$key"  ;;
    esac
}

game_loop() {
    generate_map
    PLAYER_HP=$PLAYER_MAX_HP
    PLAYER_ATTACK=$PLAYER_ATK
    PLAYER_GOLD=0
    PLAYER_LEVEL=1
    TURN=0
    KILL_COUNT=0
    SCORE=0
    LAST_MSG=""
    render ""
    local key sdmg
    while true; do
        key=$(read_key)
        LAST_MSG=""
        case "$key" in
            q|Q)
                finalize_score
                show_result "QUIT"
                break
                ;;
            w|W|a|A|s|S|d|D)
                do_move "$key"
                ;;
            space)
                do_attack
                check_dead
                LAST_MSG=" ${BY}>> 공격!${RST}"
                if check_levelup; then
                    LAST_MSG=" ${BOLD}${BY}*** LEVEL UP! Lv${PLAYER_LEVEL} ***${RST}"
                fi
                if (( BOSS_DEAD )); then
                    render ""
                    finalize_score
                    show_result "CLEAR"
                    break
                fi
                ;;
            e|E)
                do_skill
                check_dead
                LAST_MSG=" ${BOLD}${C}** 범위 스킬! ${SKILL_HITS}칸 적중! **${RST}"
                if check_levelup; then
                    LAST_MSG=" ${BOLD}${BY}*** LEVEL UP! Lv${PLAYER_LEVEL} ***${RST}"
                fi
                if (( BOSS_DEAD )); then
                    render ""
                    finalize_score
                    show_result "CLEAR"
                    break
                fi
                ;;
        esac
        (( TURN++ ))
        render ""
        if (( PLAYER_HP <= 0 )); then
            finalize_score
            show_result "DEAD"
            break
        fi
    done
}

show_title
game_loop
exit $SCORE
